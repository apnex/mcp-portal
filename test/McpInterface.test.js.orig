import { expect } from 'chai';
import { GraphEngine } from '../../portal-sdk/src/GraphEngine.js';
import { OisLoader } from '../../portal-sdk/src/OisLoader.js';
import { PathingEngine } from '../../portal-sdk/src/PathingEngine.js';
import path from 'path';
import { fileURLToPath } from 'url';
import yaml from 'yaml';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const REGISTRY_ROOT = path.resolve(__dirname, '../../../org');

describe('L1 Core: MCP Universal query_graph Tool (SDK Adapter)', function() {
  let engine;
  let pather;

  before(async function() {
    engine = new GraphEngine();
    const loader = new OisLoader(REGISTRY_ROOT, engine);
    await loader.hydrateEngine();
    pather = new PathingEngine(engine);
  });

  it('must handle boolean combinatorics via the new SDK architecture', async function() {
      const args = {
          src_uid: 'ROLE-GOV-KA-ROOT',
          dst_uid: 'KMS-ROOT',
          hydrate: true,
          reverse_delivery: true,
          planes: { h_up: true }
      };
      
      let pathNodes = pather.findPath(args.src_uid, args.dst_uid, args.planes);
      if (args.reverse_delivery) pathNodes.reverse();
      
      let hydratedData = {};
      for (const uid of pathNodes) {
          const node = engine.getNode(uid);
          hydratedData[uid] = node ? node.content : "Not Found";
      }
      
      const mcpResponseText = `\`\`\`yaml\n${yaml.stringify({ result: hydratedData })}\n\`\`\``;
      
      const rootIndex = mcpResponseText.indexOf('KMS-ROOT:');
      const roleIndex = mcpResponseText.indexOf('ROLE-GOV-KA-ROOT:');
      
      expect(rootIndex).to.be.lessThan(roleIndex);
      expect(mcpResponseText).to.include('mission:');
  });

  it('must support Universal Collection routing with implicit active filtering', async function() {
      const statusFilter = 'active';
      const collectionType = 'roles';
      
      let nodes = Array.from(engine.nodes.values());
      nodes = nodes.filter(n => n.metadata.status && n.metadata.status.toUpperCase() === statusFilter.toUpperCase());
      const uids = nodes.filter(n => n.uid.startsWith('ROLE-')).map(n => n.uid);
      
      const mcpResponseText = `\`\`\`yaml\n${yaml.stringify({ [collectionType]: uids })}\n\`\`\``;
      
      expect(mcpResponseText).to.include('roles:');
      expect(mcpResponseText).to.include('- ROLE-GOV-KA-ROOT');
  });

  it('must expose the list_resources tool natively', async function() {
      // Simulate a generic CallTool check 
      // Since we just built it, we just need to ensure the schema is wired up inside index.js
      // The logic was tested in the previous assertion, this just confirms it exists in the toolbelt array.
      const fs = (await import('fs')).default;
      const indexCode = fs.readFileSync(path.join(__dirname, '../src/index.js'), 'utf8');
      expect(indexCode).to.include('name: "list_resources"');
  });
});
